# --- Secrets / local config ---
# config.json contains Pi host, user, key path — copy from config.example.json
config.json

# --- Python ---
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# --- Training artifacts & data ---
# the model lives in models/; runs/ is raw YOLO training output
runs/
# generated by prepare_dataset.py
dataset/
# raw source images
old-snaps/
# annotation export
label-studio-project/

# --- Model weights ---
# ignore all weights except the committed trained model
*.pt
!models/best.pt
# ultralytics auto-downloads these for training
yolov8n.pt
yolo26n.pt

# --- Runtime output ---
snapshots/

# --- OS / editor ---
.DS_Store
*.swp
.idea/
.vscode/
